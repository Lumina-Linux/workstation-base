#!/bin/bash

# --- CONFIGURACIÓN DE RUTAS ---
CONF_FILE="/etc/calamares/modules/unpackfs.conf"
TAG_COMODIN="RUTA_DINAMICA_SFS"

echo "[Lumina-Wrapper] Iniciando rastreo del sistema de archivos origen..."

# 1. Rastrear dinámicamente el SquashFS en el directorio /run
# Buscamos archivos que terminen en .sfs y nos quedamos con la primera coincidencia válida
SFS_REAL_PATH=$(find /run -type f -name "*.sfs" 2>/dev/null | head -n 1)

# 2. Validar si encontramos el archivo
if [ -z "$SFS_REAL_PATH" ]; then
    echo "[Lumina-Wrapper] ERROR: No se encontró ningún archivo SquashFS (.sfs) en /run."
    echo "[Lumina-Wrapper] Abortando lanzamiento de Calamares."
    exit 1
fi

echo "[Lumina-Wrapper] ¡Bingo! SquashFS detectado en: $SFS_REAL_PATH"

# 3. Validar que el archivo de configuración de Calamares exista
if [ ! -f "$CONF_FILE" ]; then
    echo "[Lumina-Wrapper] ERROR: No se encontró el archivo de configuración en $CONF_FILE."
    exit 1
fi

# 4. Inyección quirúrgica con sed usando un delimitador alternativo (|) por las diagonales de la ruta
echo "[Lumina-Wrapper] Planchando la ruta real en unpackfs.conf..."
sed -i "s|source: \".*\"|source: \"$SFS_REAL_PATH\"|g" "$CONF_FILE"

# Opcional: Si prefieres usar la etiqueta comodín fija en lugar de reescribir la línea completa:
# sed -i "s|$TAG_COMODIN|$SFS_REAL_PATH|g" "$CONF_FILE"

echo "[Lumina-Wrapper] Configuración planchada con éxito. Lanzando Calamares..."

# 5. Ejecutar el binario real de Calamares heredando el entorno gráfico
exec calamares "$@"
